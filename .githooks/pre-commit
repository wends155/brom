#!/usr/bin/env sh
# Pre-commit hook: runs formatting, linting, and AST scanning.
# Install with: just install-hooks

echo "Running pre-commit check (fmt, clippy, sg scan)..."

cargo fmt --all --check
if [ $? -ne 0 ]; then
    echo "❌ Formatting check failed."
    exit 1
fi

cargo clippy --workspace --all-targets -- -D warnings
if [ $? -ne 0 ]; then
    echo "❌ Clippy lint check failed."
    exit 1
fi

sg scan
if [ $? -ne 0 ]; then
    echo "❌ AST-grep scan failed."
    exit 1
fi

echo "✅ Pre-commit verification passed."
exit 0

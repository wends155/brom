# brom Environment Configuration Template
# Copy this to .env and adjust as needed.

# Path to the SQLite database
DATABASE_URL=sqlite://brom.db

# Log level (info, debug, warn, error, trace)
# Supports tracing-subscriber EnvFilter syntax
BROM_LOG=info

# Comma-separated list of allowed CORS origins
BROM_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Set to false for local HTTP-only development (default: true)
BROM_SECURE_COOKIE=true

